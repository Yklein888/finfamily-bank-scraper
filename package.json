{
  "name": "finfamily-bank-scraper",
  "version": "1.0.0",
  "description": "Israeli bank scraper server for FinFamily",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "postinstall": "mkdir -p node_modules/.bin && printf '#!/bin/sh\\nexit 0\\n' > node_modules/.bin/puppeteer && chmod +x node_modules/.bin/puppeteer"
  },
  "dependencies": {
    "@sparticuz/chromium": "^119.0.2",
    "@supabase/supabase-js": "^2.39.0",
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "israeli-bank-scrapers": "^6.7.1",
    "node-cron": "^3.0.3",
    "puppeteer-core": "^22.0.0"
  },
  "overrides": {
    "puppeteer": "npm:puppeteer-core@6.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "libsodium-wrappers": "^0.8.2",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1"
  }
}
